      "writtenOn": "2026-04-09T11:09:22Z",
      "side": 1,
      "message": "question: doesn\u0027t Lustre have a function for this translation ?",
      "range": {
        "startLine": 135,
        "startChar": 16,
        "endLine": 135,
        "endChar": 23
