#ifndef ROBINHOOD_ACL_POSIX_H
#define ROBINHOOD_ACL_POSIX_H

#include "robinhood/backend.h"

#define RBH_ACL_PLUGIN_NAME "acl"

#mesondefine RBH_ACL_PLUGIN_MAJOR
#mesondefine RBH_ACL_PLUGIN_MINOR
#mesondefine RBH_ACL_PLUGIN_RELEASE
#define RBH_ACL_PLUGIN_VERSION RPV(RBH_ACL_PLUGIN_MAJOR, \
                                   RBH_ACL_PLUGIN_MINOR, \
                                   RBH_ACL_PLUGIN_RELEASE)

#define RBH_ACL_ATTR_FLAG(bits) RBH_ATTR_BACKEND_VALUE(ACL, bits)

static inline bool
rbh_attr_is_acl(uint64_t flags)
{
    return flags == 0 || RBH_ATTR_BACKEND(flags) == RBH_BI_ACL;
}

enum rbh_acl_enrich_flag {
    RBH_AEF_ALL     = 0x1,
    RBH_AEF_ACL     = RBH_ATTR_BACKEND_VALUE(ACL),
};

#endif
